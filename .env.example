# Application
CODEWIKI_APP_NAME=Code Wiki Platform
CODEWIKI_DATABASE_URL=sqlite+aiosqlite:///./data/codewiki.sqlite3
# PostgreSQL is supported for shared deployments:
# CODEWIKI_DATABASE_URL=postgresql+psycopg://codewiki:codewiki@localhost:5432/codewiki
CODEWIKI_STORAGE_DIR=./storage

# GraphRAG retrieval settings. Increase these for deeper source-grounded Wiki pages
# when your model context window can handle the larger prompt.
CODEWIKI_GRAPHRAG_CONTEXT_TOKEN_BUDGET=8000
CODEWIKI_GRAPHRAG_MAX_SOURCE_CHUNKS=20

# LLM routing mode. Keep "sdk" for direct LiteLLM SDK calls.
CODEWIKI_LLM__MODE=sdk

# Default LLM profile. Every task inherits these values unless
# CODEWIKI_LLM__PROFILES__<TASK>__* overrides are set below.
CODEWIKI_LLM__DEFAULT__MODEL=provider/strong-coding-model
CODEWIKI_LLM__DEFAULT__PROVIDER_TYPE=
CODEWIKI_LLM__DEFAULT__ENDPOINT=
CODEWIKI_LLM__DEFAULT__API_KEY=
# Optional global max output tokens. Leave commented to use task defaults.
# Set to 0 to omit provider max_tokens.
# CODEWIKI_LLM__DEFAULT__MAX_TOKENS=0

# Runtime behavior for all LLM calls.
CODEWIKI_LLM__TIMEOUT_SECONDS=120
CODEWIKI_LLM__MAX_RETRIES=3
CODEWIKI_LLM__CACHE_ENABLED=true

# Catalog generation override. Use a fast/cheap model here if desired.
CODEWIKI_LLM__PROFILES__CATALOG__MODEL=
CODEWIKI_LLM__PROFILES__CATALOG__PROVIDER_TYPE=
CODEWIKI_LLM__PROFILES__CATALOG__ENDPOINT=
CODEWIKI_LLM__PROFILES__CATALOG__API_KEY=
# CODEWIKI_LLM__PROFILES__CATALOG__MAX_TOKENS=12000

# Community summary / cluster naming override. The "cluster" task aliases this
# community_summary profile.
CODEWIKI_LLM__PROFILES__COMMUNITY_SUMMARY__MODEL=
CODEWIKI_LLM__PROFILES__COMMUNITY_SUMMARY__PROVIDER_TYPE=
CODEWIKI_LLM__PROFILES__COMMUNITY_SUMMARY__ENDPOINT=
CODEWIKI_LLM__PROFILES__COMMUNITY_SUMMARY__API_KEY=
# CODEWIKI_LLM__PROFILES__COMMUNITY_SUMMARY__MAX_TOKENS=4096

# Optional cluster-specific override. If omitted, cluster inherits community_summary.
# CODEWIKI_LLM__PROFILES__CLUSTER__MAX_TOKENS=4096

# Wiki page generation override. Use a stronger model for source-grounded pages.
CODEWIKI_LLM__PROFILES__PAGE__MODEL=
CODEWIKI_LLM__PROFILES__PAGE__PROVIDER_TYPE=
CODEWIKI_LLM__PROFILES__PAGE__ENDPOINT=
CODEWIKI_LLM__PROFILES__PAGE__API_KEY=
# CODEWIKI_LLM__PROFILES__PAGE__MAX_TOKENS=12000

# Wiki translation override. Leave empty to use the default LLM profile.
CODEWIKI_LLM__PROFILES__TRANSLATION__MODEL=
CODEWIKI_LLM__PROFILES__TRANSLATION__PROVIDER_TYPE=
CODEWIKI_LLM__PROFILES__TRANSLATION__ENDPOINT=
CODEWIKI_LLM__PROFILES__TRANSLATION__API_KEY=
# CODEWIKI_LLM__PROFILES__TRANSLATION__MAX_TOKENS=12000

# Ask/QA override. Streaming is enabled for this task by default.
CODEWIKI_LLM__PROFILES__QA__MODEL=
CODEWIKI_LLM__PROFILES__QA__PROVIDER_TYPE=
CODEWIKI_LLM__PROFILES__QA__ENDPOINT=
CODEWIKI_LLM__PROFILES__QA__API_KEY=
# CODEWIKI_LLM__PROFILES__QA__MAX_TOKENS=0

# Embedding override. Set this when your default model is not an embedding model
# and GraphRAG vector indexing is enabled.
CODEWIKI_LLM__PROFILES__EMBEDDING__MODEL=
CODEWIKI_LLM__PROFILES__EMBEDDING__PROVIDER_TYPE=
CODEWIKI_LLM__PROFILES__EMBEDDING__ENDPOINT=
CODEWIKI_LLM__PROFILES__EMBEDDING__API_KEY=

# Wiki language settings. Base language is generated first; translation
# languages are comma-separated, for example "zh,ja,ko". Set "zh" to keep
# the Chinese Wiki view populated after generating the base language.
CODEWIKI_WIKI_BASE_LANGUAGE=en
CODEWIKI_WIKI_TRANSLATION_LANGUAGES=
